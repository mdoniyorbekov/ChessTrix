{
  "name": "chesstrix",
  "version": "0.1.0",
  "private": true,
  "description": "Chesstrix - Chess arena offline desktop chess platform",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && tsc -p electron/tsconfig.json && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 node scripts/run-electron.js .",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "start": "npm run build && node scripts/run-electron.js .",
    "build:cpp": "node scripts/build-cpp.mjs",
    "build:wasm": "node scripts/build-wasm.mjs",
    "test:cpp": "node scripts/test-cpp.mjs",
    "test:wasm": "node scripts/compare-wasm-chessjs.mjs",
    "install-stockfish": "node scripts/install-stockfish.js"
  },
  "dependencies": {
    "@chess-openings/eco.json": "^2.0.4",
    "chess.js": "^1.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^8.0.10"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^40.0.0",
    "wait-on": "^7.2.0"
  }
}
